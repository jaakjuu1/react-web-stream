# ── Frontend (Vite build-time) ──────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ── Server ──────────────────────────────────────────────────
# LiveKit Cloud (server mints all tokens; keys never reach the client)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Clerk
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Svix signing secret for the Clerk webhook endpoint (/api/auth/clerk-webhook).
# Required for account deletion to propagate; create the webhook in the Clerk
# dashboard with the user.deleted event.
CLERK_WEBHOOK_SECRET=whsec_xxx
# Full public URL of the Clerk Frontend API proxy. Defaults to
# ${FRONTEND_URL}/__clerk. Must match the Proxy URL configured in the Clerk
# dashboard (Domains → Frontend API → Proxy).
CLERK_PROXY_URL=https://your-domain.example/__clerk

# Database (SQLite file; mount /app/data as a volume in production)
DATABASE_URL=file:./prisma/dev.db

# Public URL of the app — used for CORS, Stripe redirects, and pairing QR links
FRONTEND_URL=http://localhost:5173

# Stripe (optional in dev; when unset, billing checks are disabled)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Web push (optional; generate with `npx web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Cloudflare R2 clip storage (optional; falls back to local uploads/)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Set to 'true' to expose unauthenticated demo-room tokens in production.
# Never enable on a real deployment.
ENABLE_DEMO_TOKENS=
